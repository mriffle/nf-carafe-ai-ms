/*
 * Configuration for running stub tests.
 * Disables Docker so stubs run locally without pulling containers.
 * Disables reporting to avoid cluttering the test environment.
 */

docker {
    enabled = false
}

// Disable Nextflow reports during testing
timeline { enabled = false }
report   { enabled = false }
trace    { enabled = false }
dag      { enabled = false }

// Override cache directories for testing
params {
    mzml_cache_directory     = "${projectDir}/tests/work/mzml_cache"
    panorama_cache_directory = "${projectDir}/tests/work/panorama_cache"
    result_dir               = "${projectDir}/tests/work/results"
    report_dir               = "${projectDir}/tests/work/reports"
}
